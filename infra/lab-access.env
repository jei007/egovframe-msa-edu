# localhost port-forward 고정 포트 (05_start-lab-access.sh).
# 09_demo-inventory-circuit-break.sh (서킷브레이크·HPA), 10_demo-kiali-traces.sh 가 동일 포트 참조.
# macOS minikube(docker)·Windows WSL 등 NodePort/minikube ip 가 브라우저에서 안 될 때 사용합니다.
# 포트 충돌 시 값만 바꾼 뒤: ./infra/scripts/05_start-lab-access.sh stop && ... start
#
# 경로·이미지 레지스트리는 infra/config.env 를 참고하세요.

LAB_ACCESS_HOST=localhost

# 관측 (observe) — [traces] 10_demo: Kiali Traces 탭·Jaeger UI·API 검증 포트
LAB_PORT_KIALI=13001    # 09_demo: Versioned app graph | Response Code | inventory latest/risky
LAB_PORT_GRAFANA=13002
LAB_PORT_JAEGER=13003   # http://localhost:13003 — verify_tracing_jaeger_url
LAB_PORT_PROMETHEUS=13004
LAB_PORT_LOKI=13005

# 애플리케이션 (msaedu)
LAB_PORT_ORDER=18080
LAB_PORT_PAYMENT=18081
LAB_PORT_INVENTORY=18082
LAB_PORT_INGRESS=18088  # 09_demo·10_demo: POST /api/orders (CB/HPA·트레이스 트래픽 유도)
